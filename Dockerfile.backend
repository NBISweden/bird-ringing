FROM python:3.12-alpine AS base

ARG UID=1000
ARG GID=1000

RUN --mount=type=cache,id=apk-cache,target=/var/cache/apk \
    apk --cache-dir=/var/cache/apk add \
	build-base \
	ccache \
	dumb-init \
	libpq \
	libpq-dev

ENV HOME=/app
ENV XDG_CACHE_HOME="$HOME/.cache"
ENV UV_CACHE_DIR="$XDG_CACHE_HOME/uv"
ENV PIP_CACHE_DIR="$XDG_CACHE_HOME/pip"
ENV CCACHE_DIR="$XDG_CACHE_HOME/ccache"
ENV CC="ccache cc" \
    CXX="ccache c++"

RUN install -d -o "$UID" -g "$GID" "$HOME"

USER "$UID:$GID"

WORKDIR "$HOME"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

ENV UV_LINK_MODE=copy

RUN --mount=type=cache,id=pip-cache,uid="$UID",target="$PIP_CACHE_DIR" \
	pip install uv

ENV PATH="$HOME/.local/bin:$PATH"

COPY --chown="$UID:$GID" docker-entrypoint.sh .

ENTRYPOINT ["/usr/bin/dumb-init", "--"]

CMD ["./docker-entrypoint.sh"]

# ----

## Production build stage
FROM base AS prod-build

RUN --mount=type=cache,id=uv-cache,uid="$UID",target="$UV_CACHE_DIR" \
    --mount=type=cache,id=cc-cache,uid="$UID",target="$CCACHE_DIR" \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
	uv sync --frozen --no-install-project

COPY --chown="$UID:$GID" pyproject.toml .
COPY --chown="$UID:$GID" uv.lock .
COPY --chown="$UID:$GID" manage.py .
COPY --chown="$UID:$GID" system ./system
COPY --chown="$UID:$GID" bird_ringing ./bird_ringing

RUN --mount=type=cache,id=uv-cache,uid="$UID",target="$UV_CACHE_DIR" \
	uv sync --frozen

# ----

## Production stage
FROM python:3.12-alpine AS prod

ARG UID=1000
ARG GID=1000

RUN --mount=type=cache,id=apk-cache,target=/var/cache/apk \
	apk --cache-dir=/var/cache/apk add \
		dumb-init \
		libpq

ENV HOME=/app

RUN install -d -o "$UID" -g "$GID" "$HOME" /vol

USER "$UID:$GID"

WORKDIR "$HOME"

COPY --from=prod-build --chown="$UID:$GID" "$HOME" .

ENV PATH="$HOME/.venv/bin:$PATH"

VOLUME /vol

# Generate static files into the volume.
RUN ln -s /vol static
RUN python manage.py collectstatic

# Make the application read-only except for symlinks.
RUN find . -depth ! -type l -exec chmod a-w,go= {} +

ENTRYPOINT ["/usr/bin/dumb-init", "--"]

CMD ["./docker-entrypoint.sh"]

# ----

## Development stage
FROM base AS dev

ENV PATH="$HOME/.venv/bin:$PATH"
